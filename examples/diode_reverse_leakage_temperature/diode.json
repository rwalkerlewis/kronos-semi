{
  "schema_version": "2.7.0",
  "name": "diode_reverse_leakage_temperature",
  "description": "Practical 1D pn diode reverse-leakage characterization across three temperatures (250 K, 300 K, 350 K). 20 um total length, step doping at the midpoint (N_A = 1e16 cm^-3 p-side, N_D = 1e16 cm^-3 n-side), 800 cells, tau_n = tau_p = 100 ns. SRH recombination on, Auger off (low-injection regime where SRH generation in the depletion region dominates). Constant mobility (M14 reference branch). The anchor JSON pins T = 300 K and the smoke verifier reruns the configuration at T = 250 K and T = 350 K via in-process re-runs that override physics.temperature. V_F sweep [0, -5] V step 0.1 V (51 points; covers the reverse-leakage regime).",
  "dimension": 1,
  "mesh": {
    "source": "builtin",
    "extents": [
      [0.0, 2.0e-5]
    ],
    "resolution": [800],
    "regions_by_box": [
      {
        "name": "silicon",
        "tag": 1,
        "bounds": [
          [0.0, 2.0e-5]
        ]
      }
    ],
    "facets_by_plane": [
      {"name": "anode",   "tag": 1, "axis": 0, "value": 0.0},
      {"name": "cathode", "tag": 2, "axis": 0, "value": 2.0e-5}
    ]
  },
  "regions": {
    "silicon": {
      "material": "Si",
      "tag": 1,
      "role": "semiconductor"
    }
  },
  "doping": [
    {
      "region": "silicon",
      "profile": {
        "type": "step",
        "axis": 0,
        "location": 1.0e-5,
        "N_D_left": 0.0,
        "N_A_left": 1.0e+16,
        "N_D_right": 1.0e+16,
        "N_A_right": 0.0
      }
    }
  ],
  "contacts": [
    {
      "name": "anode",
      "facet": "anode",
      "type": "ohmic",
      "voltage": 0.0,
      "voltage_sweep": {
        "start": 0.0,
        "stop": -5.0,
        "step": 0.1
      }
    },
    {
      "name": "cathode",
      "facet": "cathode",
      "type": "ohmic",
      "voltage": 0.0
    }
  ],
  "physics": {
    "temperature": 300.0,
    "statistics": "boltzmann",
    "mobility": {
      "model": "constant",
      "mu_n": 1400.0,
      "mu_p": 450.0
    },
    "recombination": {
      "srh": true,
      "auger": false,
      "tau_n": 1.0e-07,
      "tau_p": 1.0e-07,
      "E_t": 0.0
    }
  },
  "solver": {
    "type": "bias_sweep",
    "snes": {
      "rtol": 1.0e-12,
      "atol": 1.0e-12,
      "stol": 1.0e-14,
      "max_it": 80
    },
    "continuation": {
      "min_step": 1.0e-04,
      "max_halvings": 8,
      "max_step": 0.1,
      "easy_iter_threshold": 4,
      "grow_factor": 1.5
    }
  },
  "output": {
    "directory": "./results/diode_reverse_leakage_temperature",
    "fields": ["potential", "n", "p"]
  }
}
