{
  "schema_version": "2.7.0",
  "name": "diode_reverse_leakage_temperature",
  "description": "Practical 1D pn diode reverse-bias leakage characterization at three temperatures (250 K, 300 K, 350 K). Geometry mirrors benchmarks/pn_1d_bias_reverse for parameter consistency: 20 um total, step junction at 10 um, N_A = N_D = 1e17 cm^-3 symmetric, SRH on with tau_n = tau_p = 1e-7 s. Anode swept from 0 V to -2 V at 0.1 V step. The anchor JSON pins T = 300 K and the smoke verifier loops over the other two temperatures via in-process re-runs that override physics.temperature. The new axis is temperature: SRH thermal generation in the depletion region (J_gen ~ q n_i W_dep / 2 tau) inherits the n_i(T) ~ T^(3/2) exp(-E_g/2kT) Arrhenius factor, so the reverse-leakage current grows steeply with temperature.",
  "dimension": 1,
  "mesh": {
    "source": "builtin",
    "extents": [
      [0.0, 2.0e-5]
    ],
    "resolution": [800],
    "regions_by_box": [
      {
        "name": "silicon",
        "tag": 1,
        "bounds": [
          [0.0, 2.0e-5]
        ]
      }
    ],
    "facets_by_plane": [
      {"name": "anode",   "tag": 1, "axis": 0, "value": 0.0},
      {"name": "cathode", "tag": 2, "axis": 0, "value": 2.0e-5}
    ]
  },
  "regions": {
    "silicon": {
      "material": "Si",
      "tag": 1,
      "role": "semiconductor"
    }
  },
  "doping": [
    {
      "region": "silicon",
      "profile": {
        "type": "step",
        "axis": 0,
        "location": 1.0e-5,
        "N_D_left": 0.0,
        "N_A_left": 1.0e+17,
        "N_D_right": 1.0e+17,
        "N_A_right": 0.0
      }
    }
  ],
  "contacts": [
    {
      "name": "anode",
      "facet": "anode",
      "type": "ohmic",
      "voltage": 0.0,
      "voltage_sweep": {
        "start": 0.0,
        "stop": -2.0,
        "step": 0.1
      }
    },
    {
      "name": "cathode",
      "facet": "cathode",
      "type": "ohmic",
      "voltage": 0.0
    }
  ],
  "physics": {
    "temperature": 300.0,
    "statistics": "boltzmann",
    "mobility": {
      "mu_n": 1400.0,
      "mu_p": 450.0
    },
    "recombination": {
      "srh": true,
      "tau_n": 1.0e-07,
      "tau_p": 1.0e-07,
      "E_t": 0.0
    }
  },
  "solver": {
    "type": "bias_sweep",
    "snes": {
      "rtol": 1.0e-12,
      "atol": 1.0e-12,
      "stol": 1.0e-14,
      "max_it": 80
    },
    "continuation": {
      "min_step": 1.0e-04,
      "max_halvings": 8,
      "max_step": 0.2,
      "easy_iter_threshold": 4,
      "grow_factor": 1.5
    }
  },
  "output": {
    "directory": "./results/diode_reverse_leakage_temperature",
    "fields": ["potential", "n", "p"]
  }
}
