{
  "schema_version": "2.7.0",
  "name": "nmos_idvgs",
  "description": "Practical n-channel MOSFET (100 nm channel, 2 nm SiO2 gate, p-type body N_A = 5e17 cm^-3, n+ source/drain Gaussian implants peak 1e20 cm^-3) demonstrating the Lombardi surface mobility (M16.2) over a Caughey-Thomas bulk branch (M16.1) under Fermi-Dirac statistics (M16.4) for the degenerate source/drain. The anchor JSON sweeps V_GS in [0, 1.8] V at V_DS = 0.05 V (linear regime). The companion saturation curve at V_DS = 1.8 V is generated by the verifier via in-process re-runs that override contacts[].voltage on the drain. CI-friendly mesh (60 x 26 cells = 1560 cells) and V_GS step (0.1 V); see README for the parameter-tuning notes.",
  "dimension": 2,
  "mesh": {
    "source": "builtin",
    "extents": [
      [0.0, 1.5e-7],
      [0.0, 5.2e-8]
    ],
    "resolution": [60, 26],
    "regions_by_box": [
      {
        "name": "silicon",
        "tag": 1,
        "bounds": [
          [0.0, 1.5e-7],
          [0.0, 5.0e-8]
        ]
      },
      {
        "name": "oxide",
        "tag": 2,
        "bounds": [
          [2.5e-8, 1.25e-7],
          [5.0e-8, 5.2e-8]
        ]
      }
    ],
    "facets_by_plane": [
      {"name": "body",   "tag": 1, "axis": 1, "value": 0.0},
      {"name": "source", "tag": 2, "axis": 0, "value": 0.0},
      {"name": "drain",  "tag": 3, "axis": 0, "value": 1.5e-7},
      {"name": "gate",   "tag": 4, "axis": 1, "value": 5.2e-8}
    ]
  },
  "regions": {
    "silicon": {
      "material": "Si",
      "tag": 1,
      "role": "semiconductor"
    },
    "oxide": {
      "material": "SiO2",
      "tag": 2,
      "role": "insulator"
    }
  },
  "doping": [
    {
      "region": "silicon",
      "profile": {
        "type": "uniform",
        "N_D": 0.0,
        "N_A": 5.0e+17
      }
    },
    {
      "region": "silicon",
      "profile": {
        "type": "gaussian",
        "center": [1.25e-8, 5.0e-8],
        "sigma": [1.0e-8, 6.0e-9],
        "peak": 1.0e+20,
        "dopant": "donor"
      }
    },
    {
      "region": "silicon",
      "profile": {
        "type": "gaussian",
        "center": [1.375e-7, 5.0e-8],
        "sigma": [1.0e-8, 6.0e-9],
        "peak": 1.0e+20,
        "dopant": "donor"
      }
    }
  ],
  "contacts": [
    {
      "name": "body",
      "facet": "body",
      "type": "ohmic",
      "voltage": 0.0
    },
    {
      "name": "source",
      "facet": "source",
      "type": "ohmic",
      "voltage": 0.0
    },
    {
      "name": "drain",
      "facet": "drain",
      "type": "ohmic",
      "voltage": 0.05
    },
    {
      "name": "gate",
      "facet": "gate",
      "type": "gate",
      "voltage": 0.0,
      "workfunction": 0.0,
      "voltage_sweep": {
        "start": 0.0,
        "stop": 1.8,
        "step": 0.1
      }
    }
  ],
  "physics": {
    "temperature": 300.0,
    "statistics": "fermi_dirac",
    "mobility": {
      "model": "lombardi",
      "bulk_model": "caughey_thomas",
      "mu_n": 1400.0,
      "mu_p": 450.0,
      "interface_facet_tag": 4
    },
    "recombination": {
      "srh": true,
      "tau_n": 1.0e-08,
      "tau_p": 1.0e-08,
      "E_t": 0.0
    }
  },
  "solver": {
    "type": "bias_sweep",
    "continuation": {
      "min_step": 1.0e-05,
      "max_halvings": 10,
      "easy_iter_threshold": 4,
      "grow_factor": 1.5
    }
  },
  "output": {
    "directory": "./results/nmos_idvgs",
    "fields": ["potential", "n", "p"]
  }
}
