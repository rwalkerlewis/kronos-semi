      "atol": 1e-10,
      "stol": 1e-14,
      "max_it": 80
    },
    "continuation": {
      "min_step": 0.0001,
      "max_halvings": 6,
      "max_step": 0.1,
      "easy_iter_threshold": 4,
      "grow_factor": 2.0
    }
  },
  "output": {
